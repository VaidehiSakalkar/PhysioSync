# ─── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret. Generate a strong random value with: openssl rand -hex 32
# MANDATORY — all Spring Boot services refuse to start without this.
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# JWT token expiry in milliseconds. Default: 86400000 = 24 hours.
JWT_EXPIRY_MS=86400000

# ─── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Database name (usually 'postgres' for Supabase).
POSTGRES_DB=postgres

# Supabase Postgres credentials.
POSTGRES_USER=postgres.[your-project-ref]
POSTGRES_PASSWORD=your_supabase_password

# JDBC URL used by Spring Boot services. Replace with your Supabase direct connection endpoint.
# Example: jdbc:postgresql://db.[your-project-ref].supabase.co:5432/postgres
POSTGRES_URL=jdbc:postgresql://db.[your-project-ref].supabase.co:5432/postgres

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection used by appointment-service (reminder deduplication) and api-gateway.
# "redis" = container service name on physiolink-net.
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ─────────────────────────────────────────────────────────────────────
# Kafka broker address. exercise-service publishes session.completed events here.
# ml-service Kafka consumer reads from this broker.
# "kafka" = container service name on physiolink-net.
KAFKA_BOOTSTRAP=kafka:9092

# ─── MinIO ─────────────────────────────────────────────────────────────────────
# MinIO S3-compatible object storage — used by video-service for recording URLs
# and exercise-service for exercise video assets.
# "minio" = container service name; port 9000 = API, 9001 = web console.
MINIO_ENDPOINT=http://minio:9000

# Root credentials for MinIO. Change these for production deployments.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bucket names auto-created on first use by each service.
MINIO_BUCKET_EXERCISES=exercises
MINIO_BUCKET_RECORDINGS=recordings

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
# Vector store for RAG (Retrieval-Augmented Generation) in the ML service.
# After starting the stack, run: docker exec physiolink-ml python -m app.langchain.embedder
# to embed the knowledge_base/ documents.
# "chromadb" = container service name on physiolink-net.
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── LLM ───────────────────────────────────────────────────────────────────────
# Google Gemini API key — used by the ML service RAG chain to generate recovery plans.
# Obtain from: https://aistudio.google.com/app/apikey
# MANDATORY for /api/ask endpoint. Without it, the RAG chain returns a stub response.
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Email ─────────────────────────────────────────────────────────────────────
# SMTP configuration for appointment-service email reminders.
# Development default: MailHog (bundled in docker-compose.dev.yml) on smtp://mailhog:1025
# — no authentication required, captures all outgoing mail at http://localhost:8025.
# For production: use a real SMTP relay (e.g. SendGrid, AWS SES, Mailgun).
MAIL_HOST=mailhog
MAIL_PORT=1025

# Leave blank for MailHog dev setup. Required for authenticated SMTP in production.
MAIL_USERNAME=
MAIL_PASSWORD=

# "From" address shown on reminder emails.
MAIL_FROM=noreply@physiolink.dev

# ─── Frontend (Vite build-time env vars) ───────────────────────────────────────
# These are baked into the React bundle at build time via Vite.
# For local dev (`npm run dev`): update to match where your services listen.
# For Docker Compose: update to the host machine's public IP or domain if needed.

# API gateway base URL — all REST API calls from the frontend go here.
VITE_API_BASE_URL=http://localhost:8080

# ML service WebSocket URL — used by SessionPage for real-time pose estimation stream.
VITE_ML_WS_URL=ws://localhost:8000

# Video service WebSocket URL — used by VideoConsultationPage for WebRTC signaling.
VITE_VIDEO_WS_URL=ws://localhost:8084
