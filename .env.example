# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRY_MS=86400000

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=physiolink
POSTGRES_USER=physio
POSTGRES_PASSWORD=physio123
POSTGRES_URL=jdbc:postgresql://postgres:5432/physiolink

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_EXERCISES=exercises
MINIO_BUCKET_RECORDINGS=recordings

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Email (dev: use MailHog smtp://mailhog:1025) ───────────────────────────────
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@physiolink.dev

# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_ML_WS_URL=ws://localhost:8000
VITE_VIDEO_WS_URL=ws://localhost:8084
